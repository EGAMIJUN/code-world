# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (managed: Supabase / Neon / RDS 等)
DATABASE_URL=postgresql://user:password@host:5432/codeworld

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis (managed: Upstash / ElastiCache 等)
REDIS_URL=rediss://user:password@host:6380

# ── Auth ──────────────────────────────────────────────────────────────────────
# 32文字以上のランダム文字列 (openssl rand -base64 32 で生成)
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# 本番 API サーバーの公開 URL
BETTER_AUTH_URL=https://api.your-domain.com

# GitHub OAuth App (本番用を別途作成)
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ── App URLs ──────────────────────────────────────────────────────────────────
WEB_URL=https://your-domain.com
NEXT_PUBLIC_WEB_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# ── Ports ─────────────────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=3001

# ── Observability (Sentry) ────────────────────────────────────────────────────
# Sentry DSN — プロジェクト設定 > Client Keys から取得
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# ブラウザ側 Sentry (NEXT_PUBLIC_ prefix で公開される)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=code-world
# Source map upload 用 (CI で設定)
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Judge0 (コード実行サンドボックス) ────────────────────────────────────────
# Option A: RapidAPI の Judge0 CE を使う場合
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-rapidapi-key
# Option B: セルフホスト Judge0 の場合
# JUDGE0_API_URL=https://judge0.your-vps.com

# ── Node / Bun ────────────────────────────────────────────────────────────────
NODE_ENV=production
